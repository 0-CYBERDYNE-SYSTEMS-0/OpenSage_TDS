# Copy this file to .env and fill in your keys:
#   cp .env.example .env

# MiniMax M2.7 (default model)
MINIMAX_API_KEY=your_minimax_jwt_token_here

# Z.AI / GLM models (coding API)
ZAI_CODING_API_KEY=your_zai_coding_api_key_here

# Google Gemini (free tier fallback)
GEMINI_API_KEY=your_gemini_api_key_here
